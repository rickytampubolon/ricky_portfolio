# EmailJS credentials — used by the contact form on the static site.
# Sign up at https://www.emailjs.com, then:
#   1. Add a Gmail service → copy the Service ID
#   2. Create an email template → copy the Template ID
#   3. Go to Account → API Keys → copy your Public Key
#
# For local dev: copy this file to .env and fill in the values.
# For GitHub Pages: add these as repository secrets and reference them in the workflow.

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
