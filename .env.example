# Web3Forms access key — used by the contact form on the static site.
# Sign up at https://web3forms.com (free, no submission limits):
#   1. Enter your email (rickytampubolon97@gmail.com) to receive your access key
#   2. Copy the access key from the email you receive
#
# For local dev: copy this file to .env and fill in the value.
# For GitHub Pages: add this as a repository secret (Settings → Secrets → Actions)
#   Secret name: VITE_WEB3FORMS_ACCESS_KEY

VITE_WEB3FORMS_ACCESS_KEY=your_access_key_here

# ── Analytics Dashboard ────────────────────────────────────────
# Secret key to protect the /dashboard page.
# Only someone who knows this value can view your analytics.
# Set a long random string (e.g. openssl rand -hex 32).
# Only used when running the Node.js backend (pnpm start).

DASHBOARD_SECRET=change_me_to_a_strong_random_string
